<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AutoBump - Discord AutoTool</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>
    <%- include('nav') %>

    <main class="container">
        <section class="page-head">
            <div>
                <div class="section-kicker">AutoBump</div>
                <h2>Serveurs et planification</h2>
                <p>Associez vos serveurs aux tokens, ajustez les délais et gardez le bump automatique sous contrôle.</p>
            </div>
            <span class="badge <%= config.enabled ? 'success' : 'danger' %>"><%= config.enabled ? 'Actif' : 'Inactif' %></span>
        </section>

        <section class="stats-grid">
            <div class="stat">
                <div class="stat-value"><%= config.servers ? config.servers.length : 0 %></div>
                <div class="stat-label">serveur(s)</div>
            </div>
            <div class="stat">
                <div class="stat-value"><%= tokens ? tokens.length : 0 %></div>
                <div class="stat-label">token(s)</div>
            </div>
            <div class="stat">
                <div class="stat-value"><%= config.settings.maxServersPerToken %></div>
                <div class="stat-label">serveurs max / token</div>
            </div>
            <div class="stat">
                <div class="stat-value"><%= config.settings.humanize ? config.settings.humanizeMin + '-' + config.settings.humanizeMax : 'OFF' %></div>
                <div class="stat-label">délai aléatoire (min)</div>
            </div>
        </section>

        <section class="main-content">
            <article class="card span-full control-card">
                <div>
                    <div class="card-topline">Contrôle</div>
                    <h2>Lancer ou arrêter AutoBump</h2>
                    <p>Démarrez le cycle automatique quand vos serveurs et tokens sont prêts.</p>
                </div>
                <div class="actions control-actions">
                    <button id="enableBtn" class="success" onclick="enableBump()">Démarrer</button>
                    <button id="disableBtn" class="danger" onclick="disableBump()">Arrêter</button>
                </div>
            </article>

            <article class="card">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Paramètres</div>
                        <h2>Rythme de bump</h2>
                    </div>
                </div>
                <form id="bumpSettingsForm" class="form-grid compact-form">
                    <div class="form-group span-full">
                        <label for="humanize">Délai aléatoire</label>
                        <select id="humanize" name="humanize">
                            <option value="true" <%= config.settings.humanize ? 'selected' : '' %>>Activer</option>
                            <option value="false" <%= !config.settings.humanize ? 'selected' : '' %>>Désactiver</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="humanizeMin">Minimum</label>
                        <input type="number" id="humanizeMin" name="humanizeMin" value="<%= config.settings.humanizeMin %>" min="1">
                    </div>
                    <div class="form-group">
                        <label for="humanizeMax">Maximum</label>
                        <input type="number" id="humanizeMax" name="humanizeMax" value="<%= config.settings.humanizeMax %>" min="1">
                    </div>
                    <div class="form-group span-full">
                        <label for="maxServersPerToken">Serveurs maximum par token</label>
                        <input type="number" id="maxServersPerToken" name="maxServersPerToken" value="<%= config.settings.maxServersPerToken %>" min="1">
                    </div>
                    <div class="form-actions span-full">
                        <button type="submit">Enregistrer</button>
                    </div>
                </form>
                <div class="modal-error" id="settingsError" hidden></div>
                <div class="alert alert-success" id="settingsSuccess" hidden>Paramètres enregistrés.</div>
            </article>

            <article class="card">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Serveur</div>
                        <h2>Ajouter une cible</h2>
                    </div>
                </div>
                <form id="addServerForm" class="form-grid compact-form">
                    <div class="form-group">
                        <label for="serverId">ID serveur</label>
                        <input type="text" id="serverId" name="serverId" placeholder="123456789" required>
                    </div>
                    <div class="form-group">
                        <label for="bumpChannelId">ID salon bump</label>
                        <input type="text" id="bumpChannelId" name="bumpChannelId" placeholder="987654321" required>
                    </div>
                    <div class="form-group span-full">
                        <label for="tokenId">Token à utiliser</label>
                        <select id="tokenId" name="tokenId" required>
                            <option value="">Sélectionner un token</option>
                            <% tokens.forEach(token => { %>
                                <option value="<%= token.id %>"><%= token.name %> (<%= token.group %>)</option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="form-actions span-full">
                        <button type="submit">Ajouter</button>
                    </div>
                </form>
                <div class="modal-error" id="serverError" hidden></div>
            </article>

            <article class="card span-full">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Inventaire</div>
                        <h2>Serveurs configurés</h2>
                    </div>
                    <span class="badge accent"><%= config.servers ? config.servers.length : 0 %> serveur(s)</span>
                </div>
                <% if (config.servers && config.servers.length > 0) { %>
                    <div class="modal-error" id="serverOrderError" hidden></div>
                    <div class="form-grid compact-form table-controls">
                        <div class="form-group">
                            <label for="bumpTableSearch">Recherche</label>
                            <input type="search" id="bumpTableSearch" placeholder="Nom, ID serveur, salon bump">
                        </div>
                        <div class="form-group">
                            <label for="bumpTableSort">Tri</label>
                            <select id="bumpTableSort">
                                <option value="manual:asc:number">Ordre manuel</option>
                                <option value="token:asc:text">Token A-Z</option>
                                <option value="enabled:desc:number">Actifs d'abord</option>
                                <option value="enabled:asc:number">Inactifs d'abord</option>
                            </select>
                        </div>
                    </div>
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Ordre</th>
                                    <th>Nom</th>
                                    <th>ID serveur</th>
                                    <th>Salon bump</th>
                                    <th>Token</th>
                                    <th>État</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="bumpServersTableBody">
                                <% config.servers.forEach(server => {
                                    const token = tokens.find(t => t.id === server.tokenId);
                                    const bumpChannelName = server.bumpChannelName || 'Salon bump';
                                %>
                                    <tr
                                        class="sortable-row server-row"
                                        draggable="true"
                                        data-server-config-id="<%= server.id %>"
                                        data-search="<%= server.name %> <%= server.serverId %> <%= bumpChannelName %> <%= server.bumpChannelId %>"
                                        data-token="<%= token ? token.name : '' %>"
                                        data-enabled="<%= server.enabled ? 1 : 0 %>"
                                    >
                                        <td>
                                            <span class="drag-handle" title="Glisser pour déplacer">|||</span>
                                        </td>
                                        <td><strong><%= server.name %></strong></td>
                                        <td><code><%= server.serverId %></code></td>
                                        <td>
                                            <strong><%= bumpChannelName %></strong><br>
                                            <code>(<%= server.bumpChannelId %>)</code>
                                        </td>
                                        <td><%= token ? token.name : 'Token introuvable' %></td>
                                        <td>
                                            <span class="badge <%= server.enabled ? 'success' : 'danger' %>">
                                                <%= server.enabled ? 'Actif' : 'Inactif' %>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="actions stacked-actions">
                                                <button
                                                    type="button"
                                                    class="<%= server.enabled ? 'secondary-button' : 'success' %>"
                                                    data-server-id="<%= server.id %>"
                                                    data-enabled="<%= server.enabled ? 'false' : 'true' %>"
                                                    onclick="toggleServer(this)"
                                                ><%= server.enabled ? 'Désactiver' : 'Activer' %></button>
                                                <div class="stacked-actions__row">
                                                    <button
                                                        type="button"
                                                        data-server-id="<%= server.id %>"
                                                        data-server-name="<%= server.name %>"
                                                        data-server-discord-id="<%= server.serverId %>"
                                                        data-bump-channel-id="<%= server.bumpChannelId %>"
                                                        data-token-id="<%= server.tokenId %>"
                                                        onclick="openEditServerModal(this)"
                                                    >Modifier</button>
                                                    <button
                                                        type="button"
                                                        class="danger"
                                                        data-server-id="<%= server.id %>"
                                                        data-server-name="<%= server.name %>"
                                                        onclick="openDeleteServerModal(this)"
                                                    >Supprimer</button>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state">Aucun serveur configuré.</div>
                <% } %>
            </article>
        </section>
    </main>

    <div class="modal-overlay" id="deleteServerModal" hidden>
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="deleteServerTitle">
            <div class="modal-header">
                <div>
                    <div class="card-topline">Suppression</div>
                    <h2 id="deleteServerTitle">Supprimer le serveur</h2>
                </div>
                <button type="button" class="ghost-button" onclick="closeDeleteServerModal()" aria-label="Fermer">&times;</button>
            </div>
            <p class="modal-copy">
                Vous allez retirer <strong id="deleteServerName">ce serveur</strong> de la liste AutoBump.
            </p>
            <input type="hidden" id="deleteServerId">
            <div class="modal-error" id="deleteServerError" hidden></div>
            <div class="modal-actions">
                <button type="button" class="secondary-button" onclick="closeDeleteServerModal()">Annuler</button>
                <button type="button" class="danger" onclick="confirmDeleteServer()">Supprimer</button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="editServerModal" hidden>
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="editServerTitle">
            <div class="modal-header">
                <div>
                    <div class="card-topline">Modification</div>
                    <h2 id="editServerTitle">Modifier le serveur</h2>
                </div>
                <button type="button" class="ghost-button" onclick="closeEditServerModal()" aria-label="Fermer">&times;</button>
            </div>
            <form id="editServerForm" class="form-grid">
                <input type="hidden" id="editServerConfigId" name="serverConfigId">
                <div class="form-group span-full">
                    <label for="editServerName">Serveur</label>
                    <input type="text" id="editServerName" disabled>
                </div>
                <div class="form-group span-full">
                    <label for="editServerDiscordId">ID serveur</label>
                    <input type="text" id="editServerDiscordId" disabled>
                </div>
                <div class="form-group">
                    <label for="editBumpChannelId">ID salon bump</label>
                    <input type="text" id="editBumpChannelId" name="bumpChannelId" required>
                </div>
                <div class="form-group">
                    <label for="editServerTokenId">Token à utiliser</label>
                    <select id="editServerTokenId" name="tokenId" required>
                        <% tokens.forEach(token => { %>
                            <option value="<%= token.id %>"><%= token.name %> (<%= token.group %>)</option>
                        <% }); %>
                    </select>
                </div>
                <div class="modal-error span-full" id="editServerError" hidden></div>
                <div class="modal-actions span-full">
                    <button type="button" class="secondary-button" onclick="closeEditServerModal()">Annuler</button>
                    <button type="submit">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('footer') %>
    <script src="/js/table-tools.js"></script>

    <script>
        const settingsError = document.getElementById('settingsError');
        const settingsSuccess = document.getElementById('settingsSuccess');
        const serverError = document.getElementById('serverError');
        const serverOrderError = document.getElementById('serverOrderError');
        const bumpServersTableBody = document.getElementById('bumpServersTableBody');
        const editServerModal = document.getElementById('editServerModal');
        const editServerForm = document.getElementById('editServerForm');
        const editServerError = document.getElementById('editServerError');
        const deleteServerModal = document.getElementById('deleteServerModal');
        const deleteServerError = document.getElementById('deleteServerError');
        let draggedServerRow = null;

        initTableTools({
            tbody: '#bumpServersTableBody',
            rowSelector: '.server-row',
            search: '#bumpTableSearch',
            sort: '#bumpTableSort'
        });

        function showInlineMessage(target, message) {
            target.textContent = message;
            target.hidden = false;
        }

        function hideInlineMessages() {
            settingsError.hidden = true;
            settingsSuccess.hidden = true;
            serverError.hidden = true;
            if (serverOrderError) {
                serverOrderError.hidden = true;
            }
            editServerError.hidden = true;
            deleteServerError.hidden = true;
        }

        document.getElementById('bumpSettingsForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            hideInlineMessages();

            const data = Object.fromEntries(new FormData(e.target));
            const res = await fetch('/api/bump/config', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();

            if (result.success) {
                showInlineMessage(settingsSuccess, 'Paramètres enregistrés.');
            } else {
                showInlineMessage(settingsError, 'Erreur: ' + result.error);
            }
        });

        document.getElementById('addServerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            hideInlineMessages();

            const data = Object.fromEntries(new FormData(e.target));
            const res = await fetch('/api/bump/server/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();

            if (result.success) {
                location.reload();
            } else {
                showInlineMessage(serverError, 'Erreur: ' + result.error);
            }
        });

        function getDragAfterServerRow(container, y) {
            const rows = [...container.querySelectorAll('.server-row:not(.dragging)')];

            return rows.reduce((closest, row) => {
                const box = row.getBoundingClientRect();
                const offset = y - box.top - box.height / 2;

                if (offset < 0 && offset > closest.offset) {
                    return { offset, row };
                }

                return closest;
            }, { offset: Number.NEGATIVE_INFINITY, row: null }).row;
        }

        async function saveServerOrder() {
            if (!bumpServersTableBody) {
                return;
            }

            const serverIds = [...bumpServersTableBody.querySelectorAll('.server-row')]
                .map(row => row.dataset.serverConfigId);

            try {
                const res = await fetch('/api/bump/server/reorder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ serverIds })
                });
                const result = await res.json();

                if (!result.success) {
                    throw new Error(result.error || "Impossible d'enregistrer l'ordre.");
                }

                if (serverOrderError) {
                    serverOrderError.hidden = true;
                    serverOrderError.textContent = '';
                }
            } catch (err) {
                if (serverOrderError) {
                    serverOrderError.textContent = err.message || "Impossible d'enregistrer l'ordre.";
                    serverOrderError.hidden = false;
                }
            }
        }

        if (bumpServersTableBody) {
            bumpServersTableBody.addEventListener('dragstart', (e) => {
                const row = e.target.closest('.server-row');
                if (!row) {
                    return;
                }

                draggedServerRow = row;
                row.classList.add('dragging');
                e.dataTransfer.effectAllowed = 'move';
                e.dataTransfer.setData('text/plain', row.dataset.serverConfigId);
            });

            bumpServersTableBody.addEventListener('dragover', (e) => {
                e.preventDefault();
                const afterRow = getDragAfterServerRow(bumpServersTableBody, e.clientY);

                if (!draggedServerRow) {
                    return;
                }

                if (afterRow) {
                    bumpServersTableBody.insertBefore(draggedServerRow, afterRow);
                } else {
                    bumpServersTableBody.appendChild(draggedServerRow);
                }
            });

            bumpServersTableBody.addEventListener('dragend', async () => {
                if (!draggedServerRow) {
                    return;
                }

                draggedServerRow.classList.remove('dragging');
                draggedServerRow = null;
                await saveServerOrder();
            });
        }

        function openEditServerModal(button) {
            document.getElementById('editServerConfigId').value = button.dataset.serverId;
            document.getElementById('editServerName').value = button.dataset.serverName || '';
            document.getElementById('editServerDiscordId').value = button.dataset.serverDiscordId || '';
            document.getElementById('editBumpChannelId').value = button.dataset.bumpChannelId || '';
            document.getElementById('editServerTokenId').value = button.dataset.tokenId || '';
            editServerError.hidden = true;
            editServerError.textContent = '';
            editServerModal.hidden = false;
            document.getElementById('editBumpChannelId').focus();
        }

        function closeEditServerModal() {
            editServerModal.hidden = true;
            editServerForm.reset();
            editServerError.hidden = true;
            editServerError.textContent = '';
        }

        editServerForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            editServerError.hidden = true;
            editServerError.textContent = '';

            const data = Object.fromEntries(new FormData(editServerForm));
            const res = await fetch('/api/bump/server/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();

            if (result.success) {
                location.reload();
            } else {
                editServerError.textContent = 'Erreur: ' + result.error;
                editServerError.hidden = false;
            }
        });

        function openDeleteServerModal(button) {
            document.getElementById('deleteServerId').value = button.dataset.serverId;
            document.getElementById('deleteServerName').textContent = button.dataset.serverName || 'ce serveur';
            deleteServerError.hidden = true;
            deleteServerError.textContent = '';
            deleteServerModal.hidden = false;
        }

        function closeDeleteServerModal() {
            deleteServerModal.hidden = true;
            document.getElementById('deleteServerId').value = '';
            deleteServerError.hidden = true;
            deleteServerError.textContent = '';
        }

        async function confirmDeleteServer() {
            const serverId = document.getElementById('deleteServerId').value;
            const res = await fetch('/api/bump/server/remove', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ serverId })
            });
            const result = await res.json();

            if (result.success) {
                location.reload();
            } else {
                showInlineMessage(deleteServerError, 'Erreur: ' + result.error);
            }
        }

        async function toggleServer(button) {
            hideInlineMessages();
            const res = await fetch('/api/bump/server/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    serverId: button.dataset.serverId,
                    enabled: button.dataset.enabled
                })
            });
            const result = await res.json();

            if (result.success) {
                location.reload();
            } else {
                showInlineMessage(serverOrderError, 'Erreur: ' + result.error);
            }
        }

        editServerModal.addEventListener('click', (e) => {
            if (e.target === editServerModal) {
                closeEditServerModal();
            }
        });

        deleteServerModal.addEventListener('click', (e) => {
            if (e.target === deleteServerModal) {
                closeDeleteServerModal();
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key !== 'Escape') {
                return;
            }

            if (!editServerModal.hidden) {
                closeEditServerModal();
            }

            if (!deleteServerModal.hidden) {
                closeDeleteServerModal();
            }
        });

        async function enableBump() {
            const res = await fetch('/api/bump/enable', { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                location.reload();
            } else {
                showInlineMessage(settingsError, 'Erreur: ' + result.error);
            }
        }

        async function disableBump() {
            const res = await fetch('/api/bump/disable', { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                location.reload();
            } else {
                showInlineMessage(settingsError, 'Erreur: ' + result.error);
            }
        }
    </script>
</body>
</html>
