<header class="app-header">
    <div class="app-header__inner">
        <div class="brand-block">
            <div class="eyebrow">Discord AutoTool</div>
            <h1>Control Center</h1>
            <p>Un tableau de bord clair pour piloter AutoBump, AutoSender, les tokens et les webhooks.</p>
        </div>
        <span class="status <%= (typeof isRunning !== 'undefined' && isRunning) ? 'running' : 'stopped' %>">
            <span class="status-dot"></span>
            <span><%= (typeof isRunning !== 'undefined' && isRunning) ? 'En cours' : 'Arrêté' %></span>
        </span>
    </div>
</header>
