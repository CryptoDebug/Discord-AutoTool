<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tokens - Discord AutoTool</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>
    <%- include('nav') %>

    <main class="container">
        <section class="page-head">
            <div>
                <div class="section-kicker">Tokens</div>
                <h2>Accès et groupes</h2>
                <p>Organisez les comptes par usage, gardez les tokens masqués et retrouvez rapidement chaque entrée.</p>
            </div>
            <span class="badge accent"><%= tokens ? tokens.length : 0 %> token(s)</span>
        </section>

        <section class="main-content">
            <article class="card">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Groupes</div>
                        <h2>Groupes de tokens</h2>
                    </div>
                </div>
                <div class="form-group">
                    <label for="newGroupName">Ajouter un groupe</label>
                    <div class="inline-control">
                        <input type="text" id="newGroupName" placeholder="Nom du groupe">
                        <button onclick="createTokenGroup()">Créer</button>
                    </div>
                </div>

                <% if (groups.tokenGroups && groups.tokenGroups.length > 0) { %>
                    <div class="chip-grid">
                        <% groups.tokenGroups.forEach(group => { %>
                            <div class="chip">
                                <span class="badge accent"><%= group %></span>
                                <button class="danger" onclick="deleteTokenGroup('<%= group %>')">Supprimer</button>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="empty-state">Aucun groupe personnalisé.</div>
                <% } %>
            </article>

            <article class="card">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Nouveau token</div>
                        <h2>Ajouter un token</h2>
                    </div>
                </div>
                <form id="addTokenForm" class="form-grid">
                    <div class="form-group span-full">
                        <label for="token">Token Discord</label>
                        <input type="password" id="token" name="token" placeholder="MTA5..." required>
                    </div>
                    <div class="form-group">
                        <label for="tokenName">Nom</label>
                        <input type="text" id="tokenName" name="name" placeholder="Compte principal">
                    </div>
                    <div class="form-group">
                        <label for="tokenGroup">Groupe</label>
                        <select id="tokenGroup" name="group">
                            <option value="default">default</option>
                            <% if (groups.tokenGroups) { groups.tokenGroups.forEach(group => { %>
                                <option value="<%= group %>"><%= group %></option>
                            <% }); } %>
                        </select>
                    </div>
                    <button type="submit">Ajouter</button>
                </form>
            </article>

            <article class="card span-full">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Inventaire</div>
                        <h2>Tokens configurés</h2>
                    </div>
                </div>
                <% if (tokens && tokens.length > 0) { %>
                    <div class="modal-error" id="tokenOrderError" hidden></div>
                    <div class="form-grid compact-form table-controls">
                        <div class="form-group">
                            <label for="tokenTableSearch">Recherche</label>
                            <input type="search" id="tokenTableSearch" placeholder="Nom ou token">
                        </div>
                        <div class="form-group">
                            <label for="tokenTableSort">Tri</label>
                            <select id="tokenTableSort">
                                <option value="manual:asc:number">Ordre manuel</option>
                                <option value="group:asc:text">Groupe A-Z</option>
                                <option value="created:desc:number">Création récente</option>
                                <option value="created:asc:number">Création ancienne</option>
                            </select>
                        </div>
                    </div>
                    <div class="table-wrap">
                        <table class="token-table">
                            <thead>
                                <tr>
                                    <th>Ordre</th>
                                    <th>Nom</th>
                                    <th>Groupe</th>
                                    <th>Token</th>
                                    <th>Créé le</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="tokensTableBody">
                                <% tokens.forEach(token => { %>
                                    <tr
                                        class="token-row"
                                        draggable="true"
                                        data-token-id="<%= token.id %>"
                                        data-search="<%= token.name %> <%= token.token %>"
                                        data-group="<%= token.group %>"
                                        data-created="<%= new Date(token.createdAt).getTime() || 0 %>"
                                    >
                                        <td>
                                            <span class="drag-handle" title="Glisser pour deplacer">|||</span>
                                        </td>
                                        <td><strong><%= token.name %></strong></td>
                                        <td><span class="badge accent"><%= token.group %></span></td>
                                        <td>
                                            <button
                                                type="button"
                                                class="token-secret"
                                                data-token="<%= token.token %>"
                                                onclick="copyToken(this)"
                                                title="Cliquer pour copier"
                                            >
                                                <span><%= token.token %></span>
                                            </button>
                                        </td>
                                        <td><%= new Date(token.createdAt).toLocaleDateString('fr-FR') %></td>
                                        <td>
                                            <div class="actions stacked-actions">
                                                <button
                                                    type="button"
                                                    class="success"
                                                    data-token-id="<%= token.id %>"
                                                    data-token-name="<%= token.name %>"
                                                    onclick="openJoinTokenModal(this)"
                                                >Rejoindre</button>
                                                <div class="stacked-actions__row">
                                                    <button
                                                        type="button"
                                                        data-token-id="<%= token.id %>"
                                                        data-token-name="<%= token.name %>"
                                                        data-token-group="<%= token.group %>"
                                                        data-token-value="<%= token.token %>"
                                                        onclick="editToken(this)"
                                                    >Modifier</button>
                                                    <button
                                                        type="button"
                                                        class="danger"
                                                        data-token-id="<%= token.id %>"
                                                        data-token-name="<%= token.name %>"
                                                        onclick="openDeleteTokenModal(this)"
                                                    >Supprimer</button>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state">Aucun token configuré.</div>
                <% } %>
            </article>
        </section>
    </main>

    <div class="modal-overlay" id="editTokenModal" hidden>
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="editTokenTitle">
            <div class="modal-header">
                <div>
                    <div class="card-topline">Modification</div>
                    <h2 id="editTokenTitle">Modifier le token</h2>
                </div>
                <button type="button" class="ghost-button" onclick="closeEditTokenModal()" aria-label="Fermer">&times;</button>
            </div>
            <form id="editTokenForm" class="form-grid">
                <input type="hidden" id="editTokenId" name="tokenId">
                <div class="form-group">
                    <label for="editTokenName">Nom</label>
                    <input type="text" id="editTokenName" name="name" placeholder="Compte principal">
                </div>
                <div class="form-group">
                    <label for="editTokenGroup">Groupe</label>
                    <select id="editTokenGroup" name="group">
                        <option value="default">Aucun groupe</option>
                        <% if (groups.tokenGroups) { groups.tokenGroups.forEach(group => { %>
                            <option value="<%= group %>"><%= group %></option>
                        <% }); } %>
                    </select>
                </div>
                <div class="form-group span-full">
                    <label for="editTokenValue">Token Discord</label>
                    <input type="password" id="editTokenValue" name="token" required>
                </div>
                <div class="modal-error span-full" id="editTokenError" hidden></div>
                <div class="modal-actions span-full">
                    <button type="button" class="secondary-button" onclick="closeEditTokenModal()">Annuler</button>
                    <button type="submit">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="deleteTokenModal" hidden>
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="deleteTokenTitle">
            <div class="modal-header">
                <div>
                    <div class="card-topline">Suppression</div>
                    <h2 id="deleteTokenTitle">Supprimer le token</h2>
                </div>
                <button type="button" class="ghost-button" onclick="closeDeleteTokenModal()" aria-label="Fermer">&times;</button>
            </div>
            <p class="modal-copy">
                Vous allez supprimer <strong id="deleteTokenName">ce token</strong>. Cette action est definitive.
            </p>
            <input type="hidden" id="deleteTokenId">
            <div class="modal-error" id="deleteTokenError" hidden></div>
            <div class="modal-actions">
                <button type="button" class="secondary-button" onclick="closeDeleteTokenModal()">Annuler</button>
                <button type="button" class="danger" onclick="confirmDeleteToken()">Supprimer</button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="joinTokenModal" hidden>
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="joinTokenTitle">
            <div class="modal-header">
                <div>
                    <div class="card-topline">Invitation</div>
                    <h2 id="joinTokenTitle">Rejoindre un serveur</h2>
                </div>
                <button type="button" class="ghost-button" onclick="closeJoinTokenModal()" aria-label="Fermer">&times;</button>
            </div>
            <form id="joinTokenForm" class="form-grid">
                <input type="hidden" id="joinTokenId" name="tokenId">
                <div class="form-group span-full">
                    <label for="joinTokenName">Token</label>
                    <input type="text" id="joinTokenName" disabled>
                </div>
                <div class="form-group span-full">
                    <label for="joinInvite">Lien d'invitation</label>
                    <input type="text" id="joinInvite" name="invite" placeholder="https://discord.gg/..." required>
                </div>
                <div class="form-group span-full" id="joinCaptchaDetails" hidden>
                    <label for="joinCaptchaInfo">Captcha hCaptcha</label>
                    <textarea id="joinCaptchaInfo" rows="5" readonly></textarea>
                </div>
                <div class="form-group span-full" id="joinCaptchaField" hidden>
                    <label for="joinCaptchaKey">Reponse captcha</label>
                    <input type="text" id="joinCaptchaKey" name="captchaKey" placeholder="Collez la reponse hCaptcha">
                </div>
                <div class="modal-error span-full" id="joinTokenError" hidden></div>
                <div class="alert alert-success span-full" id="joinTokenSuccess" hidden></div>
                <div class="modal-actions span-full">
                    <button type="button" class="secondary-button" onclick="closeJoinTokenModal()">Annuler</button>
                    <button type="submit" id="joinTokenSubmit">Rejoindre</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('footer') %>
    <script src="/js/table-tools.js"></script>

    <script>
        const editTokenModal = document.getElementById('editTokenModal');
        const editTokenForm = document.getElementById('editTokenForm');
        const editTokenError = document.getElementById('editTokenError');
        const deleteTokenModal = document.getElementById('deleteTokenModal');
        const deleteTokenError = document.getElementById('deleteTokenError');
        const joinTokenModal = document.getElementById('joinTokenModal');
        const joinTokenForm = document.getElementById('joinTokenForm');
        const joinTokenError = document.getElementById('joinTokenError');
        const joinTokenSuccess = document.getElementById('joinTokenSuccess');
        const joinCaptchaDetails = document.getElementById('joinCaptchaDetails');
        const joinCaptchaField = document.getElementById('joinCaptchaField');
        const joinCaptchaInfo = document.getElementById('joinCaptchaInfo');
        const joinCaptchaKey = document.getElementById('joinCaptchaKey');
        const joinTokenSubmit = document.getElementById('joinTokenSubmit');
        const tokensTableBody = document.getElementById('tokensTableBody');
        const tokenOrderError = document.getElementById('tokenOrderError');
        let draggedTokenRow = null;

        initTableTools({
            tbody: '#tokensTableBody',
            rowSelector: '.token-row',
            search: '#tokenTableSearch',
            sort: '#tokenTableSort'
        });

        document.getElementById('addTokenForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const data = new FormData(e.target);
            const res = await fetch('/api/tokens/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(data))
            });
            const result = await res.json();
            if (result.success) {
                alert('Token ajouté !');
                location.reload();
            } else {
                alert('Erreur: ' + result.error);
            }
        });

        async function copyToken(button) {
            const token = button.dataset.token;
            try {
                await navigator.clipboard.writeText(token);
                button.classList.add('copied');
                setTimeout(() => button.classList.remove('copied'), 900);
            } catch (err) {
                alert('Impossible de copier le token.');
            }
        }

        function getDragAfterRow(container, y) {
            const rows = [...container.querySelectorAll('.token-row:not(.dragging)')];

            return rows.reduce((closest, row) => {
                const box = row.getBoundingClientRect();
                const offset = y - box.top - box.height / 2;

                if (offset < 0 && offset > closest.offset) {
                    return { offset, row };
                }

                return closest;
            }, { offset: Number.NEGATIVE_INFINITY, row: null }).row;
        }

        async function saveTokenOrder() {
            if (!tokensTableBody) {
                return;
            }

            const tokenIds = [...tokensTableBody.querySelectorAll('.token-row')]
                .map(row => row.dataset.tokenId);

            try {
                const res = await fetch('/api/tokens/reorder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ tokenIds })
                });

                if (!res.ok) {
                    throw new Error('Route de tri indisponible. Redemarrez la GUI.');
                }

                const result = await res.json();
                if (!result.success) {
                    throw new Error(result.error || "Impossible d'enregistrer l'ordre.");
                }

                tokenOrderError.hidden = true;
                tokenOrderError.textContent = '';
            } catch (err) {
                tokenOrderError.textContent = err.message || "Impossible d'enregistrer l'ordre.";
                tokenOrderError.hidden = false;
            }
        }

        if (tokensTableBody) {
            tokensTableBody.addEventListener('dragstart', (e) => {
                const row = e.target.closest('.token-row');
                if (!row) {
                    return;
                }

                draggedTokenRow = row;
                row.classList.add('dragging');
                e.dataTransfer.effectAllowed = 'move';
                e.dataTransfer.setData('text/plain', row.dataset.tokenId);
            });

            tokensTableBody.addEventListener('dragover', (e) => {
                e.preventDefault();
                const afterRow = getDragAfterRow(tokensTableBody, e.clientY);

                if (!draggedTokenRow) {
                    return;
                }

                if (afterRow) {
                    tokensTableBody.insertBefore(draggedTokenRow, afterRow);
                } else {
                    tokensTableBody.appendChild(draggedTokenRow);
                }
            });

            tokensTableBody.addEventListener('dragend', async () => {
                if (!draggedTokenRow) {
                    return;
                }

                draggedTokenRow.classList.remove('dragging');
                draggedTokenRow = null;
                await saveTokenOrder();
            });
        }

        function editToken(button) {
            document.getElementById('editTokenId').value = button.dataset.tokenId;
            document.getElementById('editTokenName').value = button.dataset.tokenName || '';
            document.getElementById('editTokenGroup').value = button.dataset.tokenGroup || 'default';
            document.getElementById('editTokenValue').value = button.dataset.tokenValue || '';
            editTokenError.hidden = true;
            editTokenError.textContent = '';
            editTokenModal.hidden = false;
            document.getElementById('editTokenName').focus();
        }

        function closeEditTokenModal() {
            editTokenModal.hidden = true;
            editTokenForm.reset();
            editTokenError.hidden = true;
            editTokenError.textContent = '';
        }

        editTokenForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const data = Object.fromEntries(new FormData(editTokenForm));

            if (!data.token.trim()) {
                editTokenError.textContent = 'Le token ne peut pas etre vide.';
                editTokenError.hidden = false;
                return;
            }

            try {
                const res = await fetch('/api/tokens/update', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        tokenId: data.tokenId,
                        name: data.name.trim(),
                        group: data.group,
                        token: data.token.trim()
                    })
                });

                if (!res.ok) {
                    throw new Error('Route de modification indisponible. Redemarrez la GUI.');
                }

                const result = await res.json();
                if (result.success) {
                    location.reload();
                } else {
                    editTokenError.textContent = 'Erreur: ' + result.error;
                    editTokenError.hidden = false;
                }
            } catch (err) {
                editTokenError.textContent = err.message || 'Impossible de modifier le token.';
                editTokenError.hidden = false;
            }
        });

        editTokenModal.addEventListener('click', (e) => {
            if (e.target === editTokenModal) {
                closeEditTokenModal();
            }
        });

        deleteTokenModal.addEventListener('click', (e) => {
            if (e.target === deleteTokenModal) {
                closeDeleteTokenModal();
            }
        });

        joinTokenModal.addEventListener('click', (e) => {
            if (e.target === joinTokenModal) {
                closeJoinTokenModal();
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key !== 'Escape') {
                return;
            }

            if (!editTokenModal.hidden) {
                closeEditTokenModal();
            }

            if (!deleteTokenModal.hidden) {
                closeDeleteTokenModal();
            }

            if (!joinTokenModal.hidden) {
                closeJoinTokenModal();
            }
        });

        function openJoinTokenModal(button) {
            document.getElementById('joinTokenId').value = button.dataset.tokenId;
            document.getElementById('joinTokenName').value = button.dataset.tokenName || 'Token selectionne';
            joinTokenError.hidden = true;
            joinTokenError.textContent = '';
            joinTokenSuccess.hidden = true;
            joinTokenSuccess.textContent = '';
            joinCaptchaDetails.hidden = true;
            joinCaptchaField.hidden = true;
            joinCaptchaInfo.value = '';
            joinCaptchaKey.value = '';
            joinTokenSubmit.textContent = 'Rejoindre';
            joinTokenModal.hidden = false;
            document.getElementById('joinInvite').focus();
        }

        function closeJoinTokenModal() {
            joinTokenModal.hidden = true;
            joinTokenForm.reset();
            joinTokenError.hidden = true;
            joinTokenError.textContent = '';
            joinTokenSuccess.hidden = true;
            joinTokenSuccess.textContent = '';
            joinCaptchaDetails.hidden = true;
            joinCaptchaField.hidden = true;
            joinCaptchaInfo.value = '';
            joinCaptchaKey.value = '';
            joinTokenSubmit.disabled = false;
            joinTokenSubmit.textContent = 'Rejoindre';
        }

        function showJoinCaptcha(captcha) {
            const lines = [
                `Service: ${captcha.service || 'hcaptcha'}`,
                `Sitekey: ${captcha.sitekey || 'non fourni'}${captcha.sitekeyFallback ? ' (fallback Discord)' : ''}`,
                captcha.rqdata ? `rqdata: ${captcha.rqdata}` : null,
                captcha.rqtoken ? `rqtoken: ${captcha.rqtoken}` : null,
                captcha.userAgent ? `User-Agent: ${captcha.userAgent}` : null,
                captcha.raw ? `Payload brut: ${JSON.stringify(captcha.raw, null, 2)}` : null
            ].filter(Boolean);

            joinCaptchaInfo.value = lines.join('\n');
            joinCaptchaDetails.hidden = false;
            joinCaptchaField.hidden = false;
            joinCaptchaKey.focus();
            joinTokenSubmit.textContent = 'Valider le captcha';
        }

        joinTokenForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            joinTokenError.hidden = true;
            joinTokenSuccess.hidden = true;
            joinTokenSubmit.disabled = true;

            const data = Object.fromEntries(new FormData(joinTokenForm));
            if (!data.invite.trim()) {
                joinTokenError.textContent = "Le lien d'invitation est obligatoire.";
                joinTokenError.hidden = false;
                joinTokenSubmit.disabled = false;
                return;
            }

            try {
                const res = await fetch('/api/tokens/join', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        tokenId: data.tokenId,
                        invite: data.invite.trim(),
                        captchaKey: data.captchaKey?.trim()
                    })
                });

                if (!res.ok) {
                    throw new Error('Route de jointure indisponible. Redemarrez la GUI.');
                }

                const result = await res.json();
                if (result.success) {
                    joinTokenSuccess.textContent = result.alreadyJoined
                        ? `Token deja present sur ${result.name}.`
                        : `Serveur rejoint: ${result.name}.`;
                    joinTokenSuccess.hidden = false;
                    joinTokenError.hidden = true;
                    joinTokenSubmit.textContent = 'Rejoint';
                    return;
                }

                if (result.requiresCaptcha) {
                    joinTokenError.textContent = result.error || 'Captcha requis.';
                    joinTokenError.hidden = false;
                    showJoinCaptcha(result.captcha || {});
                    return;
                }

                joinTokenError.textContent = 'Erreur: ' + result.error;
                joinTokenError.hidden = false;
            } catch (err) {
                joinTokenError.textContent = err.message || 'Impossible de rejoindre le serveur.';
                joinTokenError.hidden = false;
            } finally {
                joinTokenSubmit.disabled = false;
            }
        });

        function openDeleteTokenModal(button) {
            document.getElementById('deleteTokenId').value = button.dataset.tokenId;
            document.getElementById('deleteTokenName').textContent = button.dataset.tokenName || 'ce token';
            deleteTokenError.hidden = true;
            deleteTokenError.textContent = '';
            deleteTokenModal.hidden = false;
        }

        function closeDeleteTokenModal() {
            deleteTokenModal.hidden = true;
            document.getElementById('deleteTokenId').value = '';
            deleteTokenError.hidden = true;
            deleteTokenError.textContent = '';
        }

        async function confirmDeleteToken() {
            const tokenId = document.getElementById('deleteTokenId').value;

            const res = await fetch('/api/tokens/remove', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ tokenId })
            });
            const result = await res.json();
            if (result.success) {
                location.reload();
            } else {
                deleteTokenError.textContent = 'Erreur: ' + result.error;
                deleteTokenError.hidden = false;
            }
        }

        async function createTokenGroup() {
            const groupName = document.getElementById('newGroupName').value;
            if (!groupName) {
                alert('Entrez un nom de groupe');
                return;
            }
            const res = await fetch('/api/tokens/group/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ groupName })
            });
            const result = await res.json();
            if (result.success) {
                location.reload();
            } else {
                alert('Erreur: ' + result.error);
            }
        }

        async function deleteTokenGroup(groupName) {
            if (confirm('Êtes-vous sûr ? Cela supprimera tous les tokens du groupe.')) {
                const res = await fetch('/api/tokens/group/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ groupName })
                });
                const result = await res.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Erreur: ' + result.error);
                }
            }
        }
    </script>
</body>
</html>
