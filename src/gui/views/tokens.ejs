<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tokens - Discord AutoTool</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>
    <%- include('nav') %>

    <main class="container">
        <section class="page-head">
            <div>
                <div class="section-kicker">Tokens</div>
                <h2>Accès et groupes</h2>
                <p>Organisez les comptes par usage, gardez les tokens masqués et retrouvez rapidement chaque entrée.</p>
            </div>
            <span class="badge accent"><%= tokens ? tokens.length : 0 %> token(s)</span>
        </section>

        <section class="main-content">
            <article class="card">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Groupes</div>
                        <h2>Groupes de tokens</h2>
                    </div>
                </div>
                <div class="form-group">
                    <label for="newGroupName">Ajouter un groupe</label>
                    <div class="inline-control">
                        <input type="text" id="newGroupName" placeholder="Nom du groupe">
                        <button onclick="createTokenGroup()">Créer</button>
                    </div>
                </div>

                <% if (groups.tokenGroups && groups.tokenGroups.length > 0) { %>
                    <div class="chip-grid">
                        <% groups.tokenGroups.forEach(group => { %>
                            <div class="chip">
                                <span class="badge accent"><%= group %></span>
                                <button class="danger" onclick="deleteTokenGroup('<%= group %>')">Supprimer</button>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="empty-state">Aucun groupe personnalisé.</div>
                <% } %>
            </article>

            <article class="card">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Nouveau token</div>
                        <h2>Ajouter un token</h2>
                    </div>
                </div>
                <form id="addTokenForm" class="form-grid">
                    <div class="form-group span-full">
                        <label for="token">Token Discord</label>
                        <input type="password" id="token" name="token" placeholder="MTA5..." required>
                    </div>
                    <div class="form-group">
                        <label for="tokenName">Nom</label>
                        <input type="text" id="tokenName" name="name" placeholder="Compte principal">
                    </div>
                    <div class="form-group">
                        <label for="tokenGroup">Groupe</label>
                        <select id="tokenGroup" name="group">
                            <option value="default">default</option>
                            <% if (groups.tokenGroups) { groups.tokenGroups.forEach(group => { %>
                                <option value="<%= group %>"><%= group %></option>
                            <% }); } %>
                        </select>
                    </div>
                    <button type="submit">Ajouter</button>
                </form>
            </article>

            <article class="card span-full">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Inventaire</div>
                        <h2>Tokens configurés</h2>
                    </div>
                </div>
                <% if (tokens && tokens.length > 0) { %>
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Nom</th>
                                    <th>Groupe</th>
                                    <th>Token</th>
                                    <th>Créé le</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% tokens.forEach(token => { %>
                                    <tr>
                                        <td><strong><%= token.name %></strong></td>
                                        <td><span class="badge accent"><%= token.group %></span></td>
                                        <td>
                                            <button
                                                type="button"
                                                class="token-secret"
                                                data-token="<%= token.token %>"
                                                onclick="copyToken(this)"
                                                title="Cliquer pour copier"
                                            >
                                                <span><%= token.token %></span>
                                            </button>
                                        </td>
                                        <td><%= new Date(token.createdAt).toLocaleDateString('fr-FR') %></td>
                                        <td>
                                            <div class="actions">
                                                <button
                                                    type="button"
                                                    data-token-id="<%= token.id %>"
                                                    data-token-name="<%= token.name %>"
                                                    data-token-group="<%= token.group %>"
                                                    data-token-value="<%= token.token %>"
                                                    onclick="editToken(this)"
                                                >Modifier</button>
                                                <button type="button" class="danger" onclick="removeToken('<%= token.id %>')">Supprimer</button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state">Aucun token configuré.</div>
                <% } %>
            </article>
        </section>
    </main>

    <%- include('footer') %>

    <script>
        document.getElementById('addTokenForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const data = new FormData(e.target);
            const res = await fetch('/api/tokens/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(data))
            });
            const result = await res.json();
            if (result.success) {
                alert('Token ajouté !');
                location.reload();
            } else {
                alert('Erreur: ' + result.error);
            }
        });

        async function copyToken(button) {
            const token = button.dataset.token;
            try {
                await navigator.clipboard.writeText(token);
                button.classList.add('copied');
                setTimeout(() => button.classList.remove('copied'), 900);
            } catch (err) {
                alert('Impossible de copier le token.');
            }
        }

        async function editToken(button) {
            const tokenId = button.dataset.tokenId;
            const currentName = button.dataset.tokenName || '';
            const currentGroup = button.dataset.tokenGroup || 'default';
            const currentToken = button.dataset.tokenValue || '';

            const name = prompt('Nom du token', currentName);
            if (name === null) return;

            const group = prompt('Groupe du token', currentGroup);
            if (group === null) return;

            const token = prompt('Token Discord', currentToken);
            if (token === null) return;

            if (!token.trim()) {
                alert('Le token ne peut pas etre vide.');
                return;
            }

            const res = await fetch('/api/tokens/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    tokenId,
                    name: name.trim(),
                    group: group.trim() || 'default',
                    token: token.trim()
                })
            });
            const result = await res.json();
            if (result.success) {
                alert('Token modifie !');
                location.reload();
            } else {
                alert('Erreur: ' + result.error);
            }
        }

        async function removeToken(tokenId) {
            if (!confirm('Supprimer ce token ?')) {
                return;
            }

            const res = await fetch('/api/tokens/remove', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ tokenId })
            });
            const result = await res.json();
            if (result.success) {
                alert('Token supprime !');
                location.reload();
            } else {
                alert('Erreur: ' + result.error);
            }
        }

        async function createTokenGroup() {
            const groupName = document.getElementById('newGroupName').value;
            if (!groupName) {
                alert('Entrez un nom de groupe');
                return;
            }
            const res = await fetch('/api/tokens/group/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ groupName })
            });
            const result = await res.json();
            if (result.success) {
                location.reload();
            } else {
                alert('Erreur: ' + result.error);
            }
        }

        async function deleteTokenGroup(groupName) {
            if (confirm('Êtes-vous sûr ? Cela supprimera tous les tokens du groupe.')) {
                const res = await fetch('/api/tokens/group/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ groupName })
                });
                const result = await res.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Erreur: ' + result.error);
                }
            }
        }
    </script>
</body>
</html>
