<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AutoSender - Discord AutoTool</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>
    <%- include('nav') %>

    <main class="container">
        <section class="page-head">
            <div>
                <div class="section-kicker">AutoSender</div>
                <h2>Messages récurrents</h2>
                <p>Composez les messages, choisissez les groupes et gardez une vue claire sur la file configurée.</p>
            </div>
            <span class="badge <%= config.enabled ? 'success' : 'danger' %>"><%= config.enabled ? 'Actif' : 'Inactif' %></span>
        </section>

        <section class="main-content">
            <article class="card span-full control-card">
                <div>
                    <div class="card-topline">Contrôle</div>
                    <h2>Lancer ou arrêter AutoSender</h2>
                </div>
                <div class="actions control-actions">
                    <button class="success" onclick="enableSender()">Démarrer</button>
                    <button class="danger" onclick="disableSender()">Arrêter</button>
                </div>
            </article>

            <article class="card span-full">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Configuration</div>
                        <h2>Ajouter un message récurrent</h2>
                    </div>
                </div>
                <form id="addMessageForm" class="form-grid">
                    <div class="form-group span-full">
                        <label for="content">Contenu du message</label>
                        <textarea id="content" name="content" placeholder="Tapez votre message..." required rows="4"></textarea>
                        <small>Variables disponibles: {date}, {time}, {timestamp}, {random}</small>
                    </div>

                    <label class="form-group check-row">
                        <input type="checkbox" id="useGlobalTokens" name="useGlobalTokens">
                        Utiliser tous les tokens
                    </label>

                    <div class="form-group" id="tokenGroupDiv">
                        <label for="tokenGroupId">Groupe de tokens</label>
                        <select id="tokenGroupId" name="tokenGroupId">
                            <option value="">Sélectionner</option>
                            <% groups.forEach(group => { %>
                                <option value="<%= group %>"><%= group %></option>
                            <% }); %>
                        </select>
                    </div>

                    <label class="form-group check-row">
                        <input type="checkbox" id="useGlobalChannels" name="useGlobalChannels">
                        Utiliser tous les salons globaux
                    </label>

                    <div class="form-group" id="channelGroupDiv">
                        <label for="channelGroupId">Groupe de salons</label>
                        <select id="channelGroupId" name="channelGroupId">
                            <option value="">Sélectionner</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="customDelay">Délai personnalisé (ms)</label>
                        <input type="number" id="customDelay" name="customDelay" placeholder="3500" min="1000">
                    </div>

                    <button type="submit">Ajouter le message</button>
                </form>
            </article>

            <article class="card span-full">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Inventaire</div>
                        <h2>Messages configurés</h2>
                    </div>
                    <span class="badge accent"><%= config.messages ? config.messages.length : 0 %> message(s)</span>
                </div>
                <% if (config.messages && config.messages.length > 0) { %>
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Message</th>
                                    <th>Tokens</th>
                                    <th>Salons</th>
                                    <th>Délai</th>
                                    <th>État</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% config.messages.forEach(msg => { %>
                                    <tr>
                                        <td><strong><%= msg.content.substring(0, 50) %><%= msg.content.length > 50 ? '...' : '' %></strong></td>
                                        <td><%= msg.useGlobalTokens ? 'Tous' : (msg.tokenGroupId || 'Spécifiques') %></td>
                                        <td><%= msg.useGlobalChannels ? 'Tous' : (msg.channelGroupId || 'Spécifiques') %></td>
                                        <td><%= msg.customDelay ? msg.customDelay + 'ms' : 'Défaut' %></td>
                                        <td>
                                            <span class="badge <%= msg.enabled ? 'success' : 'danger' %>">
                                                <%= msg.enabled ? 'Actif' : 'Inactif' %>
                                            </span>
                                        </td>
                                        <td>
                                            <button class="danger" onclick="removeMessage('<%= msg.id %>')">Supprimer</button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state">Aucun message configuré.</div>
                <% } %>
            </article>

        </section>
    </main>

    <%- include('footer') %>

    <script>
        document.getElementById('useGlobalTokens').addEventListener('change', (e) => {
            document.getElementById('tokenGroupDiv').style.display = e.target.checked ? 'none' : 'flex';
        });

        document.getElementById('useGlobalChannels').addEventListener('change', (e) => {
            document.getElementById('channelGroupDiv').style.display = e.target.checked ? 'none' : 'flex';
        });

        document.getElementById('addMessageForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const data = new FormData(e.target);
            const res = await fetch('/api/sender/message/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(data))
            });
            const result = await res.json();
            if (result.success) {
                alert('Message ajouté !');
                location.reload();
            } else {
                alert('Erreur: ' + result.error);
            }
        });

        async function removeMessage(messageId) {
            if (confirm('Êtes-vous sûr ?')) {
                alert('La suppression des messages n'est pas encore disponible.');
            }
        }

        async function enableSender() {
            const res = await fetch('/api/sender/enable', { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                alert('Sender démarré !');
                location.reload();
            }
        }

        async function disableSender() {
            const res = await fetch('/api/sender/disable', { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                alert('Sender arrêté !');
                location.reload();
            }
        }
    </script>
</body>
</html>
