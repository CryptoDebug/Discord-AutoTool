<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AutoSender - Discord AutoTool</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>
    <%- include('nav') %>

    <main class="container">
        <section class="page-head">
            <div>
                <div class="section-kicker">AutoSender</div>
                <h2>Messages rÃ©currents</h2>
                <p>PrÃ©parez vos messages, choisissez les tokens Ã  utiliser et pilotez l'envoi automatique.</p>
            </div>
            <span class="badge <%= config.enabled ? 'success' : 'danger' %>"><%= config.enabled ? 'Actif' : 'Inactif' %></span>
        </section>

        <section class="stats-grid">
            <div class="stat">
                <div class="stat-value"><%= config.messages ? config.messages.length : 0 %></div>
                <div class="stat-label">message(s)</div>
            </div>
            <div class="stat">
                <div class="stat-value"><%= tokens ? tokens.length : 0 %></div>
                <div class="stat-label">token(s)</div>
            </div>
            <div class="stat">
                <div class="stat-value"><%= groups ? groups.length : 0 %></div>
                <div class="stat-label">groupe(s)</div>
            </div>
            <div class="stat">
                <div class="stat-value"><%= config.settings?.delayBetweenMessages || 3.5 %></div>
                <div class="stat-label">dÃ©lai par dÃ©faut (s)</div>
            </div>
        </section>

        <section class="main-content">
            <article class="card span-full control-card">
                <div>
                    <div class="card-topline">ContrÃ´le</div>
                    <h2>Lancer ou arrÃªter AutoSender</h2>
                    <p>DÃ©marrez l'envoi automatique une fois vos messages et groupes prÃªts.</p>
                </div>
                <div class="actions control-actions">
                    <button class="success" onclick="enableSender()">DÃ©marrer</button>
                    <button class="danger" onclick="disableSender()">ArrÃªter</button>
                </div>
            </article>

            <article class="card span-full">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Nouveau message</div>
                        <h2>Composer un envoi rÃ©current</h2>
                    </div>
                </div>

                <form id="addMessageForm" class="form-grid sender-form">
                    <div class="form-group span-full">
                        <label for="content">Contenu du message</label>
                        <textarea id="content" name="content" placeholder="Tapez votre message..." required rows="5"></textarea>
                        <small>Variables disponibles: {date}, {time}, {timestamp}, {random}</small>
                    </div>

                    <div class="form-group">
                        <label for="useGlobalTokens">Tokens</label>
                        <select id="useGlobalTokens" name="useGlobalTokens">
                            <option value="false">Choisir un groupe</option>
                            <option value="true">Utiliser tous les tokens</option>
                        </select>
                    </div>

                    <div class="form-group" id="tokenGroupDiv">
                        <label for="tokenGroupId">Groupe de tokens</label>
                        <select id="tokenGroupId" name="tokenGroupId">
                            <option value="">Aucun groupe</option>
                            <% groups.forEach(group => { %>
                                <option value="<%= group %>"><%= group %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="useGlobalChannels">Salons</label>
                        <select id="useGlobalChannels" name="useGlobalChannels">
                            <option value="false">Choisir un groupe</option>
                            <option value="true">Utiliser tous les salons globaux</option>
                        </select>
                    </div>

                    <div class="form-group" id="channelGroupDiv">
                        <label for="channelGroupId">Groupe de salons</label>
                        <select id="channelGroupId" name="channelGroupId">
                            <option value="">Aucun groupe</option>
                            <% channelGroups.forEach(group => { %>
                                <option value="<%= group %>"><%= group %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="customDelay">DÃ©lai personnalisÃ© (s)</label>
                        <input type="number" id="customDelay" name="customDelay" placeholder="<%= config.settings?.delayBetweenMessages || 3.5 %>" min="1" step="0.1">
                    </div>

                    <div class="form-actions sender-save-action">
                        <button type="submit">Ajouter</button>
                    </div>
                </form>

                <div class="modal-error" id="senderError" hidden></div>
            </article>

            <article class="card span-full">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Inventaire</div>
                        <h2>Messages configurÃ©s</h2>
                    </div>
                    <span class="badge accent"><%= config.messages ? config.messages.length : 0 %> message(s)</span>
                </div>
                <% if (config.messages && config.messages.length > 0) { %>
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Message</th>
                                    <th>Tokens</th>
                                    <th>Salons</th>
                                    <th>DÃ©lai</th>
                                    <th>Ã‰tat</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% config.messages.forEach(msg => { %>
                                    <tr>
                                        <td><strong><%= msg.content.substring(0, 70) %><%= msg.content.length > 70 ? '...' : '' %></strong></td>
                                        <td><%= msg.useGlobalTokens ? 'Tous les tokens' : (msg.tokenGroupId || 'Aucun groupe') %></td>
                                        <td><%= msg.useGlobalChannels ? 'Tous les salons' : (msg.channelGroupId || 'Aucun groupe') %></td>
                                        <td><%= msg.customDelay ? msg.customDelay + ' s' : 'DÃ©faut' %></td>
                                        <td>
                                            <span class="badge <%= msg.enabled ? 'success' : 'danger' %>">
                                                <%= msg.enabled ? 'Actif' : 'Inactif' %>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="actions">
                                                <button
                                                    type="button"
                                                    class="danger"
                                                    data-message-id="<%= msg.id %>"
                                                    data-message-preview="<%= msg.content.substring(0, 60) %><%= msg.content.length > 60 ? '...' : '' %>"
                                                    onclick="openDeleteMessageModal(this)"
                                                >Supprimer</button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state">Aucun message configurÃ©.</div>
                <% } %>
            </article>
        </section>
    </main>

    <div class="modal-overlay" id="deleteMessageModal" hidden>
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="deleteMessageTitle">
            <div class="modal-header">
                <div>
                    <div class="card-topline">Suppression</div>
                    <h2 id="deleteMessageTitle">Supprimer le message</h2>
                </div>
                <button type="button" class="ghost-button" onclick="closeDeleteMessageModal()" aria-label="Fermer">&times;</button>
            </div>
            <p class="modal-copy">
                Vous allez retirer <strong id="deleteMessagePreview">ce message</strong> de la file AutoSender.
            </p>
            <input type="hidden" id="deleteMessageId">
            <div class="modal-error" id="deleteMessageError" hidden></div>
            <div class="modal-actions">
                <button type="button" class="secondary-button" onclick="closeDeleteMessageModal()">Annuler</button>
                <button type="button" class="danger" onclick="confirmDeleteMessage()">Supprimer</button>
            </div>
        </div>
    </div>

    <%- include('footer') %>

    <script>
        const senderError = document.getElementById('senderError');
        const deleteMessageModal = document.getElementById('deleteMessageModal');
        const deleteMessageError = document.getElementById('deleteMessageError');

        function setSenderError(message) {
            senderError.textContent = message;
            senderError.hidden = false;
        }

        function clearSenderError() {
            senderError.hidden = true;
            senderError.textContent = '';
            deleteMessageError.hidden = true;
            deleteMessageError.textContent = '';
        }

        function syncSenderSelectors() {
            document.getElementById('tokenGroupDiv').style.display =
                document.getElementById('useGlobalTokens').value === 'true' ? 'none' : 'flex';
            document.getElementById('channelGroupDiv').style.display =
                document.getElementById('useGlobalChannels').value === 'true' ? 'none' : 'flex';
        }

        document.getElementById('useGlobalTokens').addEventListener('change', syncSenderSelectors);
        document.getElementById('useGlobalChannels').addEventListener('change', syncSenderSelectors);
        syncSenderSelectors();

        document.getElementById('addMessageForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            clearSenderError();

            const data = Object.fromEntries(new FormData(e.target));
            const res = await fetch('/api/sender/message/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();

            if (result.success) {
                location.reload();
            } else {
                setSenderError('Erreur: ' + result.error);
            }
        });

        function openDeleteMessageModal(button) {
            document.getElementById('deleteMessageId').value = button.dataset.messageId;
            document.getElementById('deleteMessagePreview').textContent = button.dataset.messagePreview || 'ce message';
            deleteMessageError.hidden = true;
            deleteMessageError.textContent = '';
            deleteMessageModal.hidden = false;
        }

        function closeDeleteMessageModal() {
            deleteMessageModal.hidden = true;
            document.getElementById('deleteMessageId').value = '';
            deleteMessageError.hidden = true;
            deleteMessageError.textContent = '';
        }

        async function confirmDeleteMessage() {
            const messageId = document.getElementById('deleteMessageId').value;
            const res = await fetch('/api/sender/message/remove', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messageId })
            });
            const result = await res.json();

            if (result.success) {
                location.reload();
            } else {
                deleteMessageError.textContent = 'Erreur: ' + result.error;
                deleteMessageError.hidden = false;
            }
        }

        deleteMessageModal.addEventListener('click', (e) => {
            if (e.target === deleteMessageModal) {
                closeDeleteMessageModal();
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !deleteMessageModal.hidden) {
                closeDeleteMessageModal();
            }
        });

        async function enableSender() {
            clearSenderError();
            const res = await fetch('/api/sender/enable', { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                location.reload();
            } else {
                setSenderError('Erreur: ' + result.error);
            }
        }

        async function disableSender() {
            clearSenderError();
            const res = await fetch('/api/sender/disable', { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                location.reload();
            } else {
                setSenderError('Erreur: ' + result.error);
            }
        }
    </script>
</body>
</html>
