<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Webhooks - Discord AutoTool</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>
    <%- include('nav') %>

    <main class="container">
        <section class="page-head">
            <div>
                <div class="section-kicker">Webhooks</div>
                <h2>Notifications Discord</h2>
                <p>Envoyez les logs importants dans un salon Discord dédié.</p>
            </div>
            <span class="badge <%= webhooks.enabled ? 'success' : 'danger' %>"><%= webhooks.enabled ? 'Actif' : 'Inactif' %></span>
        </section>

        <section class="main-content">
            <article class="card span-full control-card">
                <div>
                    <div class="card-topline">Contrôle</div>
                    <h2>Lancer ou arrêter les notifications</h2>
                    <p>Activez l'envoi des événements vers le webhook Discord configuré.</p>
                </div>
                <div class="actions control-actions">
                    <button id="enableWebhookBtn" class="success" onclick="enableWebhooks()">Démarrer</button>
                    <button id="disableWebhookBtn" class="danger" onclick="disableWebhooks()">Arrêter</button>
                </div>
            </article>

            <article class="card span-full">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Paramètres</div>
                        <h2>Destination et niveau de logs</h2>
                    </div>
                </div>

                <form id="webhookForm" class="form-grid webhook-form">
                    <input type="hidden" id="enabled" name="enabled" value="<%= webhooks.enabled ? 'true' : 'false' %>">

                    <div class="form-group span-full">
                        <label for="url">URL du webhook Discord</label>
                        <input type="url" id="url" name="url" placeholder="https://discord.com/api/webhooks/..." value="<%= webhooks.url %>">
                    </div>

                    <div class="form-group">
                        <label for="logErrors">Erreurs</label>
                        <select id="logErrors" name="logErrors">
                            <option value="true" <%= webhooks.logErrors ? 'selected' : '' %>>Envoyer dans Discord</option>
                            <option value="false" <%= !webhooks.logErrors ? 'selected' : '' %>>Ne pas envoyer</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="logSuccess">Succès</label>
                        <select id="logSuccess" name="logSuccess">
                            <option value="true" <%= webhooks.logSuccess ? 'selected' : '' %>>Envoyer dans Discord</option>
                            <option value="false" <%= !webhooks.logSuccess ? 'selected' : '' %>>Ne pas envoyer</option>
                        </select>
                    </div>

                    <div class="form-actions webhook-save-action">
                        <button type="submit">Enregistrer</button>
                    </div>
                </form>

                <div class="notice compact-notice">
                    <h3>Créer une URL webhook</h3>
                    <ol>
                        <li>Ouvrez les paramètres du serveur Discord.</li>
                        <li>Allez dans Intégrations, puis Webhooks.</li>
                        <li>Créez un webhook, copiez son URL, puis collez-la ici.</li>
                    </ol>
                </div>

                <div class="modal-error" id="webhookError" hidden></div>
                <div class="alert alert-success" id="webhookSuccess" hidden>Configuration enregistrée.</div>
            </article>

            <article class="card span-full">
                <div class="card-header">
                    <div>
                        <div class="card-topline">Référence</div>
                        <h2>Événements envoyés</h2>
                    </div>
                </div>
                <div class="event-grid">
                    <div class="event-card">
                        <span class="badge success">Succès</span>
                        <ul>
                            <li>Bump effectué</li>
                            <li>Message envoyé</li>
                            <li>Client connecté</li>
                        </ul>
                    </div>

                    <div class="event-card">
                        <span class="badge danger">Erreurs</span>
                        <ul>
                            <li>Compte désactivé</li>
                            <li>Permissions insuffisantes</li>
                            <li>Salon supprimé</li>
                            <li>Rate limited</li>
                        </ul>
                    </div>

                    <div class="event-card">
                        <span class="badge accent">Avertissements</span>
                        <ul>
                            <li>Slowmode détecté</li>
                            <li>Compte mute</li>
                            <li>Salon non textuel</li>
                        </ul>
                    </div>
                </div>
            </article>
        </section>
    </main>

    <%- include('footer') %>

    <script>
        const webhookError = document.getElementById('webhookError');
        const webhookSuccess = document.getElementById('webhookSuccess');
        const enabledInput = document.getElementById('enabled');

        function showWebhookMessage(type, message) {
            webhookError.hidden = true;
            webhookSuccess.hidden = true;

            if (type === 'error') {
                webhookError.textContent = message;
                webhookError.hidden = false;
            } else {
                webhookSuccess.textContent = message;
                webhookSuccess.hidden = false;
            }
        }

        async function saveWebhookConfig(nextEnabled = enabledInput.value) {
            const data = Object.fromEntries(new FormData(document.getElementById('webhookForm')));
            data.enabled = nextEnabled;

            const res = await fetch('/api/webhooks/config', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();

            if (!result.success) {
                throw new Error(result.error || "Impossible d'enregistrer les webhooks.");
            }

            enabledInput.value = nextEnabled;
            return result;
        }

        document.getElementById('webhookForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            try {
                await saveWebhookConfig();
                showWebhookMessage('success', 'Configuration enregistrée.');
            } catch (err) {
                showWebhookMessage('error', 'Erreur: ' + err.message);
            }
        });

        async function enableWebhooks() {
            try {
                await saveWebhookConfig('true');
                location.reload();
            } catch (err) {
                showWebhookMessage('error', 'Erreur: ' + err.message);
            }
        }

        async function disableWebhooks() {
            try {
                await saveWebhookConfig('false');
                location.reload();
            } catch (err) {
                showWebhookMessage('error', 'Erreur: ' + err.message);
            }
        }
    </script>
</body>
</html>
